# Sanity project — see https://www.sanity.io/manage to find these
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# Write token (Editor or Administrator permission) for scripts/seed.ts only —
# generate at sanity.io/manage → project → API → Tokens. Never PUBLIC_-prefixed
# or SANITY_STUDIO_-prefixed: those get exposed to browser bundles, this must not.
SANITY_API_TOKEN=your-write-token

# Administrator-permission Sanity token, for scripts/setup-webhook.ts only —
# webhook management needs the sanity.project.webhooks grant, which the
# Editor-level SANITY_API_TOKEN above does not have. Generate at
# sanity.io/manage → project → API → Tokens.
SANITY_ADMIN_TOKEN=your-admin-token

# GitHub classic PAT (or fine-grained, scoped to just this repo with Contents:
# Read and write), for scripts/setup-webhook.ts only — used to register a
# Sanity webhook that calls GitHub's repository_dispatch API, triggering a
# rebuild/redeploy on content publish. Generate at github.com/settings/tokens.
# This token is embedded in the webhook's stored headers on Sanity's side (see
# sanity.io/manage → project → API → Webhooks), not committed anywhere here.
GITHUB_DISPATCH_TOKEN=your-github-pat
