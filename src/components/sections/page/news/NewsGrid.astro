---
/**
 * NewsGrid.astro
 * News page — full grid of all articles with a client-side category filter.
 * Reads from news.json — records missing a slug/title are dropped (guards
 * against stray non-article entries in the data file).
 * Background: bg-white
 *
 * Backend note: when API ready, replace import with:
 * const news = await fetch('/api/news').then(r => r.json())
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Card from '@components/ui/Card.astro';
import allNews from '@data/news.json';
import { withBase } from '@components/utils/paths';
import { hasStringFields } from '@components/utils/validate';

interface NewsImage {
	src: string;
	alt: string;
}

interface Article {
	title: string;
	slug: string;
	category: string;
	date: string;
	author: string;
	image: string;
	images?: NewsImage[];
	excerpt: string;
	content: string[];
	featured?: boolean;
}

const news = (allNews as Article[]).filter((n) =>
	hasStringFields<Article>(n, ['title', 'slug']),
);

// Unique categories, in first-seen order, for the filter bar
const categories = [...new Set(news.map((n) => n.category))];

function formatDate(date: string) {
	return new Date(date).toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
	});
}
---

<section class='bg-white py-24'>
	<div class='max-w-7xl mx-auto px-6'>
		<SectionHeading
			label='Latest Updates'
			title='News & Announcements'
			subtitle='Programme launches, partnerships, and stories from the communities we work alongside.'
		/>

		<!-- Filter bar -->
		<div
			class='flex flex-wrap justify-center gap-3 mt-12'
			role='group'
			aria-label='Filter news by category'
		>
			<button
				type='button'
				class='project-filter-btn px-5 py-2 rounded-full text-sm font-heading font-semibold border-2 border-primary bg-primary text-white transition-colors duration-200'
				data-filter='all'
				aria-pressed='true'
			>
				All
			</button>
			{
				categories.map((category) => (
					<button
						type='button'
						class='project-filter-btn px-5 py-2 rounded-full text-sm font-heading font-semibold border-2 border-primary text-primary hover:bg-primary hover:text-white transition-colors duration-200'
						data-filter={category}
						aria-pressed='false'
					>
						{category}
					</button>
				))
			}
		</div>

		<!-- Grid -->
		<div
			class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mt-16'
			id='project-grid'
		>
			{
				news.map((article) => (
					<div
						class='project-card'
						data-category={article.category}
					>
						<Card
							layout='vertical'
							image={article.image}
							imageAlt={article.title}
							title={article.title}
							category={article.category}
							description={article.excerpt}
							impact={`Published ${formatDate(article.date)}`}
							href={`/news/${article.slug}`}
						/>
					</div>
				))
			}
		</div>

		<!-- Empty state — shown when a filter matches nothing -->
		<p
			id='project-empty-state'
			class='hidden text-center text-text-muted font-body mt-16'
		>
			No news found in this category yet.
		</p>
	</div>
</section>

<!-- External, non-processed script — CSP: script-src 'self' works with zero exceptions -->
<script
	src={withBase('/scripts/project-filter.js')}
	is:inline
></script>
