---
/**
 * AboutSummary.astro
 * Two-column about snapshot — text left, image right.
 * Background: bg-white. Stacks vertically on mobile.
 */

import Button from '../../../ui/Button.astro';
import SectionHeading from '../../../ui/SectionHeading.astro';
---

<section class='bg-white py-24'>
	<div
		class='max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center'
	>
		<!-- Left: Text -->
		<div class='flex flex-col gap-6'>
			<SectionHeading
				align='left'
				label='Who We Are'
				title='Committed to Changing Lives'
				subtitle='BethGold Foundation is a registered NGO dedicated to uplifting individuals with disabilities and underserved communities through education, health, and empowerment.'
			/>

			<p class='font-body text-text-muted leading-relaxed'>
				We believe that in every disability there is ability. Our
				programs are designed to remove barriers, build dignity, and
				create lasting change — one person, one family, one community at
				a time.
			</p>

			<div>
				<Button
					variant='outline'
					href='/about'
					>Learn More About Us</Button
				>
			</div>
		</div>

		<!-- Right: Image -->
		<div class='order-first lg:order-last'>
			<img
				src='/images/about-community.jpg'
				alt='BethGold Foundation community members'
				class='rounded-2xl shadow-md object-cover w-full h-96 lg:h-full'
				loading='lazy'
			/>
		</div>
	</div>
</section>
