---
/**
 * GalleryGrid.astro
 * Gallery page — full grid of photos with a client-side category filter.
 * Reads from gallery.json.
 * Background: bg-white
 *
 * Reuses public/scripts/project-filter.js unmodified — its selectors
 * (.project-filter-btn / .project-card / #project-empty-state) are hardcoded
 * literals, not project-specific, so this grid intentionally keeps the same
 * class/id names rather than duplicating the script under new names.
 *
 * Backend note: when API ready, replace import with:
 * const gallery = await fetch('/api/gallery').then(r => r.json())
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Card from '@components/ui/Card.astro';
import allGallery from '@data/gallery.json';
import { withBase } from '@components/utils/paths';
import { hasStringFields } from '@components/utils/validate';

interface Photo {
	category: string;
	image: string;
	alt: string;
	caption?: string;
}

const gallery = (allGallery as Photo[]).filter((p) =>
	hasStringFields<Photo>(p, ['image', 'category']),
);

// Unique categories, in first-seen order, for the filter bar
const categories = [...new Set(gallery.map((p) => p.category))];
---

<section class='bg-white py-24'>
	<div class='max-w-7xl mx-auto px-6'>
		<SectionHeading
			label='Photo Gallery'
			title='Moments From Our Work'
			subtitle='Browse photos from our programmes, events, and community — filter by category to explore.'
		/>

		<!-- Filter bar -->
		<div
			class='flex flex-wrap justify-center gap-3 mt-12'
			role='group'
			aria-label='Filter gallery by category'
		>
			<button
				type='button'
				class='project-filter-btn px-5 py-2 rounded-full text-sm font-heading font-semibold border-2 border-primary bg-primary text-white transition-colors duration-200'
				data-filter='all'
				aria-pressed='true'
			>
				All
			</button>
			{
				categories.map((category) => (
					<button
						type='button'
						class='project-filter-btn px-5 py-2 rounded-full text-sm font-heading font-semibold border-2 border-primary text-primary hover:bg-primary hover:text-white transition-colors duration-200'
						data-filter={category}
						aria-pressed='false'
					>
						{category}
					</button>
				))
			}
		</div>

		<!-- Grid -->
		<div
			class='grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6 mt-16'
			id='project-grid'
		>
			{
				gallery.map((photo) => (
					<div
						class='project-card'
						data-category={photo.category}
					>
						<Card
							layout='vertical'
							image={photo.image}
							imageAlt={photo.alt}
							category={photo.category}
							description={photo.caption}
							descriptionClass='text-text-muted text-center'
						/>
					</div>
				))
			}
		</div>

		<!-- Empty state — shown when a filter matches nothing -->
		<p
			id='project-empty-state'
			class='hidden text-center text-text-muted font-body mt-16'
		>
			No photos found in this category yet.
		</p>
	</div>
</section>

<!-- External, non-processed script — CSP: script-src 'self' works with zero exceptions -->
<script
	src={withBase('/scripts/project-filter.js')}
	is:inline
></script>
