---
/**
 * RelatedNews.astro
 * Individual news article page — up to 3 other articles, same type
 * prioritized, falling back to the most recent other articles so the
 * section never renders near-empty.
 * Background: bg-bg-base
 *
 * Props:
 *   currentSlug — slug of the article being viewed (excluded from results)
 *   type        — current article's type, used to prioritize matches
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Card from '@components/ui/Card.astro';
import allNews from '@data/news.json';
import { formatDate, toSortableTimestamp } from '@components/utils/dates';

interface Article {
	title: string;
	slug: string;
	type: string;
	date: string;
	image: string;
	excerpt: string;
}

const { currentSlug, type } = Astro.props;

const others = (allNews as Article[]).filter(
	(n) => n && typeof n.slug === 'string' && n.slug !== currentSlug,
);
const sameType = others.filter((n) => n.type === type);
const rest = others
	.filter((n) => n.type !== type)
	.sort((a, b) => toSortableTimestamp(b.date) - toSortableTimestamp(a.date));
const related = [...sameType, ...rest].slice(0, 3);
---

{
	related.length > 0 && (
		<section class='bg-bg-base py-24'>
			<div class='max-w-7xl mx-auto px-6 flex flex-col gap-16'>
				<SectionHeading
					label='Keep Reading'
					title='Related News'
				/>
				<div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8'>
					{related.map((article) => (
						<Card
							layout='vertical'
							image={article.image}
							imageAlt={article.title}
							title={article.title}
							category={article.type}
							description={article.excerpt}
							impact={formatDate(article.date) ? `Published ${formatDate(article.date)}` : undefined}
							href={`/news/${article.slug}`}
						/>
					))}
				</div>
			</div>
		</section>
	)
}
