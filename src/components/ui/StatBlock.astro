---
/**
 * StatBlock.astro
 * Individual impact statistic display with a mini bar chart.
 * Used inside ImpactStats section (bg-primary background — all text is white).
 *
 * Props:
 *   label     — descriptor text (e.g. "People Supported")
 *   value     — formatted value string (e.g. "2,000+")
 *   chartData — array of numbers 0–100 representing relative bar heights
 *
 * CSP note: bar height/opacity vary per data point, so they can't be
 * pre-declared as static CSS classes like PageHero's backgrounds can. Instead
 * each bar carries its raw value in a data-value attribute, and an external
 * script (/scripts/chart-bars.js) sets height/opacity via the CSSOM
 * (element.style.height = ...) after load. CSSOM property assignment is not
 * restricted by style-src, unlike an inline style="" attribute, so this
 * renders correctly even under a strict CSP with no style-src exceptions.
 * Astro automatically dedupes this script tag even though StatBlock repeats.
 */

import { withBase } from '../../utils/paths';

const { label, value, chartData = [] } = Astro.props;
---

<div class='flex flex-col items-center gap-4 text-center'>
	<!-- Main value -->
	<span class='font-heading text-5xl font-bold text-white'>
		{value}
	</span>

	<!-- Label -->
	<span class='font-body text-sm uppercase tracking-widest text-white/70'>
		{label}
	</span>

	<!-- Mini bar chart -->
	<div
		class='flex items-end gap-1 h-10'
		aria-hidden='true'
	>
		{
			chartData.map((v: number) => (
				<div
					class='chart-bar w-3 rounded-sm bg-white transition-all'
					data-value={v}
				/>
			))
		}
	</div>
</div>

<script
	src={withBase('/scripts/chart-bars.js')}
	is:inline
></script>
