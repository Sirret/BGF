---
/**
 * Navbar.astro
 * Sticky top navbar — white background, no blur, no dark overlay.
 * Desktop: horizontal nav links + Donate CTA.
 * Mobile: hamburger toggles a dropdown panel — no DaisyUI drawer.
 * Reads org name, logo, tagline from site.json.
 */

import site from '../data/site.json';
import { withBase } from '../utils/paths';

const navLinks = [
	{ label: 'Home', href: '/' },
	{ label: 'About', href: '/about' },
	{ label: 'Projects', href: '/projects' },
	{ label: 'Impact', href: '/impact' },
	{ label: 'Get Involved', href: '/get-involved' },
	{ label: 'News', href: '/news' },
	{ label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class='sticky top-0 z-50 bg-white border-b border-border shadow-sm'>
	<div class='max-w-7xl mx-auto px-6 flex items-center justify-between h-20'>
		<!-- Logo + Org Name -->
		<a
			href={withBase('/')}
			class='flex items-center gap-3 flex-shrink-0'
		>
			<img
				src={withBase(site.org.logo)}
				alt={`${site.org.name} logo`}
				class='h-12 w-auto object-contain'
			/>
			<div class='hidden sm:flex flex-col leading-tight'>
				<span
					class='font-heading font-bold text-text-dark text-base tracking-tight'
				>
					{site.org.name.toUpperCase()}
				</span>
				<span class='font-body text-xs text-text-muted'>
					{site.org.tagline}
				</span>
			</div>
		</a>

		<!-- Desktop Nav Links — hidden below lg -->
		<nav class='hidden lg:flex items-center gap-6'>
			{
				navLinks.map((link) => (
					<a
						href={withBase(link.href)}
						class={`font-body text-sm transition-colors duration-200 ${
							currentPath === withBase(link.href)
								? 'text-accent font-semibold'
								: 'text-text-dark hover:text-accent'
						}`}
					>
						{link.label}
					</a>
				))
			}
		</nav>

		<!-- Right side: Donate + Hamburger -->
		<div class='flex items-center gap-3'>
			<!-- Donate — always visible -->
			<a
				href={withBase('/donate')}
				class='inline-flex items-center justify-center font-heading font-semibold rounded-full px-5 py-2.5 text-sm bg-accent text-white hover:bg-accent-dark transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2'
			>
				Donate Now
			</a>

			<!-- Hamburger button — mobile only -->
			<button
				id='nav-toggle'
				class='lg:hidden p-2 rounded-lg text-text-dark hover:text-accent hover:bg-accent/5 transition-colors duration-200'
				aria-label='Toggle navigation menu'
				aria-expanded='false'
				aria-controls='mobile-menu'
			>
				<!-- Hamburger icon -->
				<svg
					id='icon-open'
					xmlns='http://www.w3.org/2000/svg'
					class='h-6 w-6'
					fill='none'
					viewBox='0 0 24 24'
					stroke='currentColor'
				>
					<path
						stroke-linecap='round'
						stroke-linejoin='round'
						stroke-width='2'
						d='M4 6h16M4 12h16M4 18h16'
					></path>
				</svg>
				<!-- Close icon -->
				<svg
					id='icon-close'
					xmlns='http://www.w3.org/2000/svg'
					class='h-6 w-6 hidden'
					fill='none'
					viewBox='0 0 24 24'
					stroke='currentColor'
				>
					<path
						stroke-linecap='round'
						stroke-linejoin='round'
						stroke-width='2'
						d='M6 18L18 6M6 6l12 12'
					></path>
				</svg>
			</button>
		</div>
	</div>

	<!-- Mobile Menu Panel — hidden by default, toggled by JS -->
	<div
		id='mobile-menu'
		class='hidden lg:hidden border-t border-border bg-white'
	>
		<nav class='max-w-7xl mx-auto px-6 py-4 flex flex-col gap-1'>
			{
				navLinks.map((link) => (
					<a
						href={withBase(link.href)}
						class={`font-body text-base py-2.5 px-3 rounded-lg transition-colors duration-200 ${
							currentPath === withBase(link.href)
								? 'text-accent font-semibold bg-accent/5'
								: 'text-text-dark hover:text-accent hover:bg-accent/5'
						}`}
					>
						{link.label}
					</a>
				))
			}

			<div class='border-t border-border mt-3 pt-3'>
				<a
					href={withBase('/donate')}
					class='inline-flex w-full items-center justify-center font-heading font-semibold rounded-full px-6 py-3 text-base bg-accent text-white hover:bg-accent-dark transition-all duration-200'
				>
					Donate Now
				</a>
			</div>
		</nav>
	</div>
</header>

<!-- External, non-processed script — CSP: script-src 'self' works with zero exceptions -->
<script
	src={withBase('/scripts/nav-toggle.js')}
	is:inline
></script>
