---
/**
 * pages/donate.astro
 * Donate page — imports sections only. Zero design logic or inline
 * classes here. Content sourced from donate.json (see src/data/donate.json).
 * Bank/mobile money values are still placeholders there — update the JSON,
 * not this file, once real details are ready.
 *
 * Section order:
 *   1. PageHero      — slim branded banner
 *   2. WaysToGive    — bank transfer + mobile money details (bg-white)
 *   3. OtherWaysCTA  — volunteer / contact fallback (bg-bg-base)
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/ui/PageHero.astro';
import WaysToGive from '@components/sections/page/donate/WaysToGive.astro';
import OtherWaysCTA from '@components/sections/page/donate/OtherWaysCTA.astro';
import site from '@data/site.json';
import donate from '@data/donate.json';
---

<BaseLayout
	title='Donate'
	description={`Support ${site.org.name} — help us empower communities through education, health, and community development.`}
>
	<PageHero
		title={donate.hero.title}
		subtitle={donate.hero.subtitle}
		breadcrumb={donate.hero.breadcrumb}
		backgroundImage={donate.hero.backgroundImage}
	/>
	<WaysToGive
		data={donate.waysToGiveSection}
		orgName={site.org.name}
	/>
	<OtherWaysCTA data={donate.otherWaysSection} />
</BaseLayout>
