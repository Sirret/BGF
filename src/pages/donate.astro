---
/**
 * pages/donate.astro
 * Donate page — PLACEHOLDER for Phase 8 (Get Involved).
 * Built now so /donate resolves to a real, on-brand page instead of the
 * generic "Coming Soon" 404 fallback, since Donate is the primary CTA
 * linked from Navbar, Footer, and AboutCallToAction.
 *
 * TODO (Phase 8): replace placeholder bank / mobile money details below
 * with real values — ideally sourced from a donate.json data file once
 * DonateInfo content is finalized, matching the about.json pattern.
 *
 * Section order:
 *   1. PageHero      — slim branded banner
 *   2. WaysToGive    — bank transfer + mobile money details (bg-white)
 *   3. OtherWaysCTA  — volunteer / contact fallback (bg-bg-base)
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/ui/PageHero.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import Button from '@components/ui/Button.astro';
import site from '@data/site.json';
import { withBase } from '@components/utils/paths';
---

<BaseLayout
	title='Donate'
	description={`Support ${site.org.name} — help us empower communities through education, health, and community development.`}
>
	<PageHero
		title='Support Our Work'
		subtitle='Every contribution helps us reach more communities.'
		breadcrumb='Donate'
	/>

	<!-- Ways to Give — bg-white -->
	<section class='bg-white py-24'>
		<div class='max-w-7xl mx-auto px-6 flex flex-col gap-16'>
			<SectionHeading
				label='Ways to Give'
				title='Choose How You Like to Donate'
				subtitle='Your support directly funds our education, health, and community programs.'
			/>

			<div class='grid grid-cols-1 sm:grid-cols-2 gap-8'>
				<!-- Bank Transfer -->
				<div
					class='bg-white rounded-2xl shadow-sm border border-border p-8 flex flex-col gap-4'
				>
					<span
						class='text-xs font-heading font-semibold uppercase tracking-widest text-accent'
					>
						Bank Transfer
					</span>
					<h3 class='font-heading text-xl font-bold text-text-dark'>
						Direct Bank Donation
					</h3>
					<!-- TODO: replace with real bank details -->
					<ul
						class='text-sm text-text-muted leading-relaxed flex flex-col gap-1'
					>
						<li>
							<span class='font-semibold text-text-dark'
								>Bank Name:</span
							> TBD
						</li>
						<li>
							<span class='font-semibold text-text-dark'
								>Account Name:</span
							>
							{site.org.name}
						</li>
						<li>
							<span class='font-semibold text-text-dark'
								>Account Number:</span
							> TBD
						</li>
						<li>
							<span class='font-semibold text-text-dark'
								>Swift Code:</span
							> TBD
						</li>
					</ul>
				</div>

				<!-- Mobile Money -->
				<div
					class='bg-white rounded-2xl shadow-sm border border-border p-8 flex flex-col gap-4'
				>
					<span
						class='text-xs font-heading font-semibold uppercase tracking-widest text-accent'
					>
						Mobile Money
					</span>
					<h3 class='font-heading text-xl font-bold text-text-dark'>
						Mobile Money Donation
					</h3>
					<!-- TODO: replace with real mobile money details -->
					<ul
						class='text-sm text-text-muted leading-relaxed flex flex-col gap-1'
					>
						<li>
							<span class='font-semibold text-text-dark'
								>Provider:</span
							> TBD
						</li>
						<li>
							<span class='font-semibold text-text-dark'
								>Number:</span
							>
							{site.contact.phone}
						</li>
						<li>
							<span class='font-semibold text-text-dark'
								>Registered Name:</span
							>
							{site.org.name}
						</li>
					</ul>
				</div>
			</div>

			<p class='text-sm text-text-muted text-center max-w-2xl mx-auto'>
				Have questions about donating, or want a receipt for your
				contribution?
				<a
					href={withBase('/contact')}
					class='text-accent font-semibold hover:underline'
					>Contact us</a
				>
				— we're happy to help.
			</p>
		</div>
	</section>

	<!-- Other Ways to Help — bg-bg-base, soft transition before footer -->
	<section class='bg-bg-base py-24'>
		<div
			class='max-w-3xl mx-auto px-6 flex flex-col items-center text-center gap-8'
		>
			<SectionHeading
				label='Prefer Another Way?'
				title='There Are Many Ways to Support Us'
				subtitle='Financial giving is just one option — volunteering and partnerships make a difference too.'
			/>
			<div class='flex flex-wrap justify-center gap-4'>
				<Button
					variant='accent'
					href='/get-involved'
					>Volunteer With Us</Button
				>
				<Button
					variant='outline'
					href='/contact'
					>Get in Touch</Button
				>
			</div>
		</div>
	</section>
</BaseLayout>
