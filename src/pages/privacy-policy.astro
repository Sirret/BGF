---
/**
 * pages/privacy-policy.astro
 * Privacy Policy page — imports sections only. Zero design logic or inline
 * classes here. Content sourced from privacy-policy.json — edit there, not
 * here, to change the policy text.
 *
 * Section order:
 *   1. PageHero              — slim branded banner
 *   2. PrivacyPolicyContent  — the policy itself (bg-white)
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/ui/PageHero.astro';
import PrivacyPolicyContent from '@components/sections/page/privacy-policy/PrivacyPolicyContent.astro';
import privacyPolicy from '@data/privacy-policy.json';
import site from '@data/site.json';
---

<BaseLayout
	title='Privacy Policy'
	description={`How ${site.org.name} collects, uses, and protects your information.`}
>
	<PageHero
		title={privacyPolicy.hero.title}
		subtitle={privacyPolicy.hero.subtitle}
		breadcrumb={privacyPolicy.hero.breadcrumb}
		backgroundImage={privacyPolicy.hero.backgroundImage}
	/>
	<PrivacyPolicyContent data={privacyPolicy} />
</BaseLayout>
