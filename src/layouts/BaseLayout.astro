---
/**
 * BaseLayout.astro
 * Root layout — wraps every page.
 * Imports global CSS, loads fonts via @fontsource, renders Navbar + Footer.
 *
 * Props:
 *   title       — <title> tag content (default: org name)
 *   description — <meta description> content
 */

import '../styles/global.css';
import '@fontsource/poppins/700.css';
import '@fontsource/open-sans/400.css';
import '@fontsource/open-sans/600.css';

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
import { withBase } from '../utils/paths';
const { title = site.org.name, description = site.org.subline } = Astro.props;
---

<!doctype html>
<html
	lang='en'
	data-theme='bethgold'
>
	<head>
		<meta charset='UTF-8' />
		<meta
			name='viewport'
			content='width=device-width, initial-scale=1.0'
		/>
		<meta
			name='description'
			content={description}
		/>
		<meta
			name='generator'
			content={Astro.generator}
		/>

		<!-- Open Graph -->
		<meta
			property='og:title'
			content={title}
		/>
		<meta
			property='og:description'
			content={description}
		/>
		<meta
			property='og:image'
			content={withBase(site.org.logo)}
		/>
		<meta
			property='og:type'
			content='website'
		/>

		<link
			rel='icon'
			type='image/jpeg'
			href={withBase(site.org.logo)}
		/>

		<title>{title} | {site.org.name}</title>
	</head>
	<body>
		<Navbar />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
