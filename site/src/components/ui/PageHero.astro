---
/**
 * PageHero.astro
 * Shared slim hero banner for all inner pages (About, Projects, Impact, etc.).
 * Full-width background image with bg-primary/75 blue overlay.
 * NOT full-screen — uses py-32 to give consistent height across pages.
 *
 * Props:
 *   title           — main page heading
 *   subtitle        — optional tagline or short description beneath heading
 *   breadcrumb      — label shown in breadcrumb trail (e.g. "About Us")
 *   backgroundImage — a Sanity `imageWithAlt` field value, or undefined
 *
 * CSP note: the background URL is applied client-side via the CSSOM
 * (public/scripts/hero-bg.js), not an inline style="" attribute — same
 * "no inline styles" discipline as StatBlock.astro's chart-bars.js. No
 * backgroundImage renders a plain bg-primary panel instead of silently
 * falling back to another page's image.
 */

import { urlFor } from '@lib/sanity/image';
import { withBase } from '@components/utils/paths';
import type { SanityImage } from '@lib/sanity/queries';

interface Props {
	title: string;
	subtitle?: string;
	breadcrumb?: string;
	backgroundImage?: SanityImage;
}

const { title, subtitle, breadcrumb, backgroundImage } = Astro.props;

const heroBgUrl = backgroundImage
	? `url(${urlFor(backgroundImage).width(1920).height(700).fit('crop').auto('format').url()})`
	: undefined;
---

<section
	class='relative bg-cover bg-center bg-no-repeat py-32 bg-primary'
	data-hero-bg-url={heroBgUrl}
>
	<div class='absolute inset-0 bg-primary/75'></div>

	<div
		class='relative z-10 max-w-7xl mx-auto px-6 flex flex-col items-center justify-center text-center gap-5'
	>
		{
			breadcrumb && (
				<nav
					class='flex items-center gap-2 text-white/60 text-sm font-body'
					aria-label='Breadcrumb'
				>
					<a
						href={withBase('/')}
						class='hover:text-white transition-colors duration-200'
					>
						Home
					</a>
					<span aria-hidden='true'>/</span>
					<span class='text-white font-medium'>{breadcrumb}</span>
				</nav>
			)
		}

		<h1
			class='font-heading font-bold text-white text-4xl md:text-5xl max-w-3xl leading-tight tracking-tight'
		>
			{title}
		</h1>

		{
			subtitle && (
				<p class='font-body text-white/80 text-lg max-w-xl leading-relaxed'>
					{subtitle}
				</p>
			)
		}
	</div>
</section>

<!-- External, non-processed script — CSP: script-src 'self' works with zero exceptions -->
<script
	src={withBase('/scripts/hero-bg.js')}
	is:inline
></script>
