---
/**
 * ContactInfo.astro
 * Contact page — direct contact details + social links. Reads ALL values
 * from Sanity siteSettings (single source of truth — same as Footer.astro),
 * never hardcoded. Icon markup reused from Footer.astro's Contact column/social row.
 * Background: bg-white
 *
 * Props: data — infoSection object from contactPage (label/title/subtitle only)
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import { getSiteSettings } from '@lib/sanity/queries';

const { data } = Astro.props;
const site = await getSiteSettings();

// Icon shapes reused verbatim from Footer.astro's social row — only the
// href values (from site.json) differ per page.
const socialLinks = [
	{
		name: 'Facebook',
		href: site.social.facebook,
		path: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z',
	},
	{ name: 'Instagram', href: site.social.instagram, icon: 'instagram' },
	{
		name: 'Twitter / X',
		href: site.social.twitter,
		path: 'M4 4l16 16M4 20L20 4',
	},
	{
		name: 'LinkedIn',
		href: site.social.linkedin,
		path: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z',
	},
];
---

<section class='bg-white py-24'>
	<div class='max-w-3xl mx-auto px-6 flex flex-col gap-12'>
		<SectionHeading
			label={data.label}
			title={data.title}
			subtitle={data.subtitle}
		/>

		<div class='grid grid-cols-1 sm:grid-cols-2 gap-6'>
			<!-- Email -->
			<a
				href={`mailto:${site.contact.email}`}
				class='flex items-start gap-3 p-5 rounded-xl border border-border hover:border-accent transition-colors duration-200'
			>
				<svg
					xmlns='http://www.w3.org/2000/svg'
					class='h-5 w-5 mt-0.5 text-accent flex-shrink-0'
					fill='none'
					viewBox='0 0 24 24'
					stroke='currentColor'
					stroke-width='1.5'
				>
					<path
						stroke-linecap='round'
						stroke-linejoin='round'
						d='M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'
					></path>
				</svg>
				<div class='flex flex-col gap-0.5'>
					<span class='text-sm font-semibold text-text-dark'>Email</span>
					<span class='text-sm text-text-muted'>{site.contact.email}</span>
				</div>
			</a>

			<!-- Phone -->
			<a
				href={`tel:${site.contact.phone}`}
				class='flex items-start gap-3 p-5 rounded-xl border border-border hover:border-accent transition-colors duration-200'
			>
				<svg
					xmlns='http://www.w3.org/2000/svg'
					class='h-5 w-5 mt-0.5 text-accent flex-shrink-0'
					fill='none'
					viewBox='0 0 24 24'
					stroke='currentColor'
					stroke-width='1.5'
				>
					<path
						stroke-linecap='round'
						stroke-linejoin='round'
						d='M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z'
					></path>
				</svg>
				<div class='flex flex-col gap-0.5'>
					<span class='text-sm font-semibold text-text-dark'>Phone</span>
					<span class='text-sm text-text-muted'>{site.contact.phone}</span>
					<span class='text-sm text-text-muted'>{site.contact.phone2}</span>
				</div>
			</a>

			<!-- Address -->
			<div
				class='flex items-start gap-3 p-5 rounded-xl border border-border'
			>
				<svg
					xmlns='http://www.w3.org/2000/svg'
					class='h-5 w-5 mt-0.5 text-accent flex-shrink-0'
					fill='none'
					viewBox='0 0 24 24'
					stroke='currentColor'
					stroke-width='1.5'
				>
					<path
						stroke-linecap='round'
						stroke-linejoin='round'
						d='M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z'
					></path>
					<path
						stroke-linecap='round'
						stroke-linejoin='round'
						d='M15 11a3 3 0 11-6 0 3 3 0 016 0z'
					></path>
				</svg>
				<div class='flex flex-col gap-0.5'>
					<span class='text-sm font-semibold text-text-dark'>Address</span>
					<span class='text-sm text-text-muted'>{site.contact.address}</span>
				</div>
			</div>

			<!-- Social -->
			<div
				class='flex items-start gap-3 p-5 rounded-xl border border-border'
			>
				<div class='flex flex-col gap-2 w-full'>
					<span class='text-sm font-semibold text-text-dark'>Follow Us</span>
					<div class='flex items-center gap-4'>
						{
							socialLinks.map((link) => (
								<a
									href={link.href}
									target='_blank'
									rel='noopener noreferrer'
									class='text-text-muted hover:text-accent transition-colors duration-200'
									aria-label={link.name}
								>
									{link.icon === 'instagram' ? (
										<svg
											xmlns='http://www.w3.org/2000/svg'
											class='h-5 w-5'
											fill='none'
											viewBox='0 0 24 24'
											stroke='currentColor'
											stroke-width='1.5'
										>
											<rect
												x='2'
												y='2'
												width='20'
												height='20'
												rx='5'
												ry='5'
											/>
											<circle
												cx='12'
												cy='12'
												r='4'
											/>
											<circle
												cx='17.5'
												cy='6.5'
												r='0.5'
												fill='currentColor'
												stroke='none'
											/>
										</svg>
									) : (
										<svg
											xmlns='http://www.w3.org/2000/svg'
											class='h-5 w-5'
											fill='none'
											viewBox='0 0 24 24'
											stroke='currentColor'
											stroke-width='1.5'
										>
											<path d={link.path}></path>
										</svg>
									)}
								</a>
							))
						}
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
