---
/**
 * ContactForm.astro
 * Contact page — message form. Submits via Web3Forms
 * (https://web3forms.com) — free, unlimited submissions, no backend needed,
 * works on static hosts like GitHub Pages.
 *
 * SETUP: this form's access key is centralized in site.json
 * (forms.web3formsAccessKey) — every Web3Forms-powered form on the site
 * reads from there, so replace it in that one place before launch.
 * Get one free at https://web3forms.com — just needs an email address to
 * receive submissions at, no account/dashboard required.
 *
 * Background: bg-bg-base
 *
 * Props: data — formSection object from contact.json
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Button from '@components/ui/Button.astro';
import site from '@data/site.json';
import { withBase } from '@components/utils/paths';

const { data } = Astro.props;

const WEB3FORMS_ACCESS_KEY = site.forms.web3formsAccessKey;
---

<section class='bg-bg-base py-24'>
	<div class='max-w-3xl mx-auto px-6 flex flex-col gap-12'>
		<SectionHeading
			label={data.label}
			title={data.title}
			subtitle={data.subtitle}
		/>

		<form
			id='contact-form'
			data-web3form
			class='flex flex-col gap-6'
			data-success-message={data.successMessage}
			data-error-message={data.errorMessage}
			data-fallback-email={site.contact.email}
		>
			<input
				type='hidden'
				name='access_key'
				value={WEB3FORMS_ACCESS_KEY}
			/>
			<input
				type='hidden'
				name='subject'
				value='New Contact Message — BethGold Foundation'
			/>
			<!-- Honeypot spam trap — must stay empty; hidden from real users -->
			<input
				type='checkbox'
				name='botcheck'
				class='hidden'
				style='display:none'
				tabindex='-1'
				autocomplete='off'
			/>

			<div class='grid grid-cols-1 sm:grid-cols-2 gap-6'>
				<div class='flex flex-col gap-2'>
					<label
						for='name'
						class='text-sm font-semibold text-text-dark'
						>Full Name</label
					>
					<input
						id='name'
						name='name'
						type='text'
						required
						class='border border-border rounded-lg px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary'
					/>
				</div>
				<div class='flex flex-col gap-2'>
					<label
						for='email'
						class='text-sm font-semibold text-text-dark'
						>Email</label
					>
					<input
						id='email'
						name='email'
						type='email'
						required
						class='border border-border rounded-lg px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary'
					/>
				</div>
			</div>

			<div class='flex flex-col gap-2'>
				<label
					for='message'
					class='text-sm font-semibold text-text-dark'
					>Message</label
				>
				<textarea
					id='message'
					name='message'
					rows='5'
					required
					placeholder='How can we help?'
					class='border border-border rounded-lg px-4 py-3 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-primary resize-none'
				></textarea>
			</div>

			<p class='text-xs text-text-muted'>
				By submitting this form, you agree to our{' '}
				<a
					href={withBase('/privacy-policy')}
					class='text-accent font-semibold hover:underline'
				>
					Privacy Policy
				</a>.
			</p>

			<Button
				variant='accent'
				type='submit'
				class='w-fit'
			>
				{data.submitLabel}
			</Button>

			<p
				data-form-status
				class='text-sm font-semibold hidden'
				role='status'
			>
			</p>
		</form>
	</div>
</section>
