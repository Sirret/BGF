---
/**
 * ProjectDetailHero.astro
 * Individual project page — slim branded banner, same visual language as
 * PageHero.astro (bg-hero-about, bg-primary/75 overlay — reused intentionally,
 * see PageHero for the CSP-safe .bg-hero-* class pattern), plus project-specific
 * category/status badges and a location/date meta row that PageHero doesn't support.
 *
 * Props:
 *   project — a single project object from projects.json
 */

import { withBase } from '@components/utils/paths';
import { formatDate } from '@components/utils/dates';

const { project } = Astro.props;

const statusLabel: Record<string, string> = {
	completed: 'Completed',
	ongoing: 'Ongoing',
};

const formattedDate = formatDate(project.date, { year: 'numeric', month: 'long' });
---

<section class='relative bg-cover bg-center bg-no-repeat py-32 bg-hero-about'>
	<div class='absolute inset-0 bg-primary/75'></div>

	<div
		class='relative z-10 max-w-4xl mx-auto px-6 flex flex-col items-center text-center gap-5'
	>
		<!-- Breadcrumb -->
		<nav
			class='flex items-center gap-2 text-white/60 text-sm font-body flex-wrap justify-center'
			aria-label='Breadcrumb'
		>
			<a
				href={withBase('/')}
				class='hover:text-white transition-colors duration-200'
			>
				Home
			</a>
			<span aria-hidden='true'>/</span>
			<a
				href={withBase('/projects')}
				class='hover:text-white transition-colors duration-200'
			>
				Projects
			</a>
			<span aria-hidden='true'>/</span>
			<span class='text-white font-medium'>{project.title}</span>
		</nav>

		<!-- Category + status badges -->
		<div class='flex items-center gap-3 flex-wrap justify-center'>
			<span
				class='text-xs font-heading font-semibold uppercase tracking-widest text-white bg-white/10 border border-white/20 px-4 py-1 rounded-full'
			>
				{project.category}
			</span>
			{
				project.status && (
					<span class='text-xs font-semibold px-3 py-1 rounded-full bg-white/10 border border-white/20 text-white'>
						{statusLabel[project.status] ?? project.status}
					</span>
				)
			}
		</div>

		<!-- Title -->
		<h1
			class='font-heading font-bold text-white text-4xl md:text-5xl leading-tight tracking-tight'
		>
			{project.title}
		</h1>

		<!-- Meta row -->
		<div
			class='flex items-center gap-6 text-white/80 text-sm font-body flex-wrap justify-center'
		>
			{
				project.location && (
					<span class='flex items-center gap-1.5'>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							class='w-4 h-4'
							fill='none'
							viewBox='0 0 24 24'
							stroke='currentColor'
							stroke-width='1.5'
						>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								d='M15 10.5a3 3 0 11-6 0 3 3 0 016 0z'
							/>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								d='M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z'
							/>
						</svg>
						{project.location}
					</span>
				)
			}
			{
				formattedDate && (
					<span class='flex items-center gap-1.5'>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							class='w-4 h-4'
							fill='none'
							viewBox='0 0 24 24'
							stroke='currentColor'
							stroke-width='1.5'
						>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								d='M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0V11.25a2.25 2.25 0 012.25-2.25h13.5a2.25 2.25 0 012.25 2.25v7.5'
							/>
						</svg>
						{formattedDate}
					</span>
				)
			}
		</div>
	</div>
</section>
