---
/**
 * NewsDetailHero.astro
 * Individual news article page — slim branded banner, same visual language as
 * PageHero.astro (dynamic Sanity background image applied client-side via
 * public/scripts/hero-bg.js, bg-primary/75 overlay — reused intentionally),
 * plus article-specific category badge and a date/author meta row that
 * PageHero doesn't support.
 *
 * Props:
 *   article — a single article document from Sanity
 */

import { withBase } from '@components/utils/paths';
import { formatDate } from '@components/utils/dates';
import { urlFor } from '@lib/sanity/image';

const { article } = Astro.props;

const formattedDate = formatDate(article.date);

const heroBgUrl = article.image
	? `url(${urlFor(article.image).width(1920).height(700).fit('crop').auto('format').url()})`
	: undefined;
---

<section
	class='relative bg-cover bg-center bg-no-repeat py-32 bg-primary'
	data-hero-bg-url={heroBgUrl}
>
	<div class='absolute inset-0 bg-primary/75'></div>

	<div
		class='relative z-10 max-w-4xl mx-auto px-6 flex flex-col items-center text-center gap-5'
	>
		<!-- Breadcrumb -->
		<nav
			class='flex items-center gap-2 text-white/60 text-sm font-body flex-wrap justify-center'
			aria-label='Breadcrumb'
		>
			<a
				href={withBase('/')}
				class='hover:text-white transition-colors duration-200'
			>
				Home
			</a>
			<span aria-hidden='true'>/</span>
			<a
				href={withBase('/news')}
				class='hover:text-white transition-colors duration-200'
			>
				News
			</a>
			<span aria-hidden='true'>/</span>
			<span class='text-white font-medium'>{article.title}</span>
		</nav>

		<!-- Category badge -->
		<span
			class='text-xs font-heading font-semibold uppercase tracking-widest text-white bg-white/10 border border-white/20 px-4 py-1 rounded-full'
		>
			{article.type}
		</span>

		<!-- Title -->
		<h1
			class='font-heading font-bold text-white text-4xl md:text-5xl leading-tight tracking-tight'
		>
			{article.title}
		</h1>

		<!-- Meta row -->
		<div
			class='flex items-center gap-6 text-white/80 text-sm font-body flex-wrap justify-center'
		>
			{
				article.author && (
					<span class='flex items-center gap-1.5'>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							class='w-4 h-4'
							fill='none'
							viewBox='0 0 24 24'
							stroke='currentColor'
							stroke-width='1.5'
						>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								d='M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z'
							/>
						</svg>
						{article.author}
					</span>
				)
			}
			{
				formattedDate && (
					<span class='flex items-center gap-1.5'>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							class='w-4 h-4'
							fill='none'
							viewBox='0 0 24 24'
							stroke='currentColor'
							stroke-width='1.5'
						>
							<path
								stroke-linecap='round'
								stroke-linejoin='round'
								d='M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0V11.25a2.25 2.25 0 012.25-2.25h13.5a2.25 2.25 0 012.25 2.25v7.5'
							/>
						</svg>
						{formattedDate}
					</span>
				)
			}
		</div>
	</div>
</section>

<!-- External, non-processed script — CSP: script-src 'self' works with zero exceptions -->
<script
	src={withBase('/scripts/hero-bg.js')}
	is:inline
></script>
