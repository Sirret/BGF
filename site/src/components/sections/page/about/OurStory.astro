---
/**
 * OurStory.astro
 * About page — "Our Story" section.
 * All text and image content pulled from Sanity aboutPage — edit there, not here.
 * Layout: text left, image right (stacks on mobile).
 * Background: bg-white
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Button from '@components/ui/Button.astro';
import { getAboutPage } from '@lib/sanity/queries';
import { urlFor } from '@lib/sanity/image';

const about = await getAboutPage();
const { story } = about;
const storyImageUrl = urlFor(story.image).width(900).height(700).fit('crop').auto('format').url();
---

<section class='bg-white py-24'>
	<div
		class='max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center'
	>
		<!-- Left: Text -->
		<div class='flex flex-col gap-8'>
			<SectionHeading
				align='left'
				label={story.label}
				title={story.heading}
			/>

			<div
				class='flex flex-col gap-5 font-body text-text-muted leading-relaxed text-base'
			>
				{story.paragraphs.map((p: string) => <p>{p}</p>)}
			</div>

			<Button
				variant='outline'
				href={story.ctaHref}
			>
				{story.ctaLabel}
			</Button>
		</div>

		<!-- Right: Image -->
		<div class='w-full h-96 lg:h-[520px]'>
			<img
				src={storyImageUrl}
				alt={story.image.alt}
				class='w-full h-full object-cover rounded-2xl shadow-md'
				loading='lazy'
			/>
		</div>
	</div>
</section>
