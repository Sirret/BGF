---
/**
 * AboutCallToAction.astro
 * About page — closing CTA section.
 * All content pulled from src/data/about.json — edit there, not here.
 * Background: bg-bg-base
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Button from '@components/ui/Button.astro';
import about from '@data/about.json';
import { withBase } from '@components/utils/paths';

const { cta } = about;
---

<section class='bg-bg-base py-24'>
	<div
		class='max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center'
	>
		<!-- Left: Text + Buttons -->
		<div class='flex flex-col gap-8'>
			<SectionHeading
				align='left'
				label={cta.label}
				title={cta.heading}
				subtitle={cta.subtitle}
			/>
			<div class='flex flex-wrap gap-4'>
				<Button
					variant='accent'
					href='/donate'
					>Donate Now</Button
				>
				<Button
					variant='outline'
					href='/get-involved'
					>Volunteer With Us</Button
				>
				<Button
					variant='ghost'
					href='/contact'
					>Get in Touch →</Button
				>
			</div>
		</div>

		<!-- Right: Image -->
		<div class='w-full h-80 lg:h-96'>
			<img
				src={withBase(cta.image)}
				alt={cta.imageAlt}
				class='w-full h-full object-cover rounded-2xl shadow-lg'
				loading='lazy'
			/>
		</div>
	</div>
</section>
