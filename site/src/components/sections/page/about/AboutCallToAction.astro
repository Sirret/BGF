---
/**
 * AboutCallToAction.astro
 * About page — closing CTA section.
 * All content pulled from Sanity aboutPage — edit there, not here.
 * Background: bg-bg-base
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Button from '@components/ui/Button.astro';
import { getAboutPage } from '@lib/sanity/queries';
import { urlFor } from '@lib/sanity/image';

const about = await getAboutPage();
const { cta } = about;
const ctaImageUrl = urlFor(cta.image).width(800).height(650).fit('crop').auto('format').url();
---

<section class='bg-bg-base py-24'>
	<div
		class='max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center'
	>
		<!-- Left: Text + Buttons -->
		<div class='flex flex-col gap-8'>
			<SectionHeading
				align='left'
				label={cta.label}
				title={cta.heading}
				subtitle={cta.subtitle}
			/>
			<div class='flex flex-wrap gap-4'>
				<Button
					variant='accent'
					href='/donate'
					>Donate Now</Button
				>
				<Button
					variant='outline'
					href='/get-involved'
					>Volunteer With Us</Button
				>
				<Button
					variant='ghost'
					href='/contact'
					>Get in Touch →</Button
				>
			</div>
		</div>

		<!-- Right: Image -->
		<div class='w-full h-80 lg:h-96'>
			<img
				src={ctaImageUrl}
				alt={cta.image.alt}
				class='w-full h-full object-cover rounded-2xl shadow-lg'
				loading='lazy'
			/>
		</div>
	</div>
</section>
