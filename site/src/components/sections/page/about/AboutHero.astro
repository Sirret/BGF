---
/**
 * AboutHero.astro
 * Thin shell — reads hero config from Sanity aboutPage and passes it to the shared PageHero component.
 */

import PageHero from '@components/ui/PageHero.astro';
import { getAboutPage } from '@lib/sanity/queries';

const about = await getAboutPage();
---

<PageHero
  title={about.hero.title}
  subtitle={about.hero.subtitle}
  breadcrumb={about.hero.breadcrumb}
  backgroundImage={about.hero.backgroundImage}
/>
