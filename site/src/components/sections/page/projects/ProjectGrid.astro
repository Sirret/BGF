---
/**
 * ProjectGrid.astro
 * Projects page — full grid of all projects with a client-side category filter.
 * Reads from Sanity `project` documents.
 * Background: bg-white
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Card from '@components/ui/Card.astro';
import { getAllProjects } from '@lib/sanity/queries';
import { withBase } from '@components/utils/paths';

const projects = await getAllProjects();

// Unique category names, in first-seen order, for the filter bar. Filtering
// (project-filter.js) matches on category `name`, not `title` — keep these
// consistent with FocusAreas.astro's anchor-matching, which is also name-based.
const categories = [...new Set(projects.map((p) => p.category.name))];
---

<section class='bg-white py-24'>
	<div class='max-w-7xl mx-auto px-6'>
		<SectionHeading
			label='Our Work'
			title='All Projects'
			subtitle='Browse every programme we have delivered — filter by focus area to find what matters most to you.'
		/>

		<!-- Filter bar -->
		<div
			class='flex flex-wrap justify-center gap-3 mt-12'
			role='group'
			aria-label='Filter projects by category'
		>
			<button
				type='button'
				class='project-filter-btn px-5 py-2 rounded-full text-sm font-heading font-semibold border-2 border-primary bg-primary text-white transition-colors duration-200'
				data-filter='all'
				aria-pressed='true'
			>
				All
			</button>
			{
				categories.map((category) => (
					<button
						type='button'
						class='project-filter-btn px-5 py-2 rounded-full text-sm font-heading font-semibold border-2 border-primary text-primary hover:bg-primary hover:text-white transition-colors duration-200'
						data-filter={category}
						aria-pressed='false'
					>
						{category}
					</button>
				))
			}
		</div>

		<!-- Grid -->
		<div
			class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mt-16'
			id='project-grid'
		>
			{
				projects.map((project) => (
					<div
						class='project-card'
						data-category={project.category.name}
					>
						<Card
							layout='vertical'
							image={project.image}
							imageAlt={project.title}
							title={project.title}
							category={project.category.name}
							status={project.status}
							description={project.description}
							impact={project.impact}
							href={`/projects/${project.slug}`}
						/>
					</div>
				))
			}
		</div>

		<!-- Empty state — shown when a filter matches nothing -->
		<p
			id='project-empty-state'
			class='hidden text-center text-text-muted font-body mt-16'
		>
			No projects found in this category yet.
		</p>
	</div>
</section>

<!-- External, non-processed script — CSP: script-src 'self' works with zero exceptions -->
<script
	src={withBase('/scripts/project-filter.js')}
	is:inline
></script>
