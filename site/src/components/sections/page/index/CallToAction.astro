---
/**
 * CallToAction.astro
 * Final homepage CTA — get involved section.
 * Two columns: text + buttons left, community image right.
 * Background: bg-bg-base. Stacks on mobile, image below.
 *
 * Props: data — callToAction object from homePage
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Button from '@components/ui/Button.astro';
import { urlFor } from '@lib/sanity/image';

const { data } = Astro.props;
const imageUrl = urlFor(data.image).width(800).height(650).fit('crop').auto('format').url();
---

<section class='bg-bg-base py-24'>
	<div
		class='max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center'
	>
		<!-- Left: Text + Buttons -->
		<div class='flex flex-col gap-6'>
			<SectionHeading
				align='left'
				label={data.label}
				title={data.title}
				subtitle={data.subtitle}
			/>

			<p class='font-body text-text-muted leading-relaxed'>
				{data.paragraph}
			</p>

			<div class='flex flex-wrap gap-4'>
				{
					data.buttons.map((button: { label: string; href: string; variant: string }) => (
						<Button variant={button.variant} href={button.href}>
							{button.label}
						</Button>
					))
				}
			</div>
		</div>

		<!-- Right: Image -->
		<div>
			<img
				src={imageUrl}
				alt={data.image.alt}
				class='rounded-2xl shadow-lg object-cover w-full h-96'
				loading='lazy'
			/>
		</div>
	</div>
</section>
