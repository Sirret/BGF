---
/**
 * AboutSummary.astro
 * Two-column about snapshot — text left, image right.
 * Background: bg-white. Stacks vertically on mobile.
 *
 * Props: data — aboutSummary object from homePage
 */

import Button from '@components/ui/Button.astro';
import SectionHeading from '@components/ui/SectionHeading.astro';
import { urlFor } from '@lib/sanity/image';

const { data } = Astro.props;
const imageUrl = urlFor(data.image).width(900).height(700).fit('crop').auto('format').url();
---

<section class='bg-white py-24'>
	<div
		class='max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center'
	>
		<!-- Left: Text -->
		<div class='flex flex-col gap-6'>
			<SectionHeading
				align='left'
				label={data.label}
				title={data.title}
				subtitle={data.subtitle}
			/>

			<p class='font-body text-text-muted leading-relaxed'>
				{data.paragraph}
			</p>

			<div>
				<Button
					variant='outline'
					href={data.ctaHref}
					>{data.ctaLabel}</Button
				>
			</div>
		</div>

		<!-- Right: Image -->
		<div class='order-first lg:order-last'>
			<img
				src={imageUrl}
				alt={data.image.alt}
				class='rounded-2xl shadow-md object-cover w-full h-96 lg:h-full'
				loading='lazy'
			/>
		</div>
	</div>
</section>
