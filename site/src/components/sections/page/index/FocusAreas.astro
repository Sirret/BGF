---
/**
 * FocusAreas.astro
 * 5-column grid of focus area cards with icons.
 * Background: bg-bg-base. Uses Card (vertical, no image) + slot for icon.
 *
 * Content comes from Sanity `category` documents — only entries with
 * `featured: true` show up here (categories also back the Projects page
 * filter bar; not every category deserves a homepage spotlight card).
 * Edit categories in Studio, not this file, to change title/description/icon.
 */

import SectionHeading from '@components/ui/SectionHeading.astro'
import Card from '@components/ui/Card.astro'
import { getFeaturedCategories, getUsedProjectCategoryNames } from '@lib/sanity/queries'
import { getIcon } from '@components/utils/icons'

const [areas, usedCategoryNames] = await Promise.all([
  getFeaturedCategories(),
  getUsedProjectCategoryNames(),
])

// Build-time checks — a category rename/typo used to break this deep link
// silently (the /projects#<anchor> hash would just do nothing). Fail loudly
// instead so it can't ship unnoticed.
for (const area of areas) {
  if (!area.name.toLowerCase().startsWith(area.anchor.toLowerCase())) {
    throw new Error(
      `category "${area.name}"'s anchor "${area.anchor}" doesn't match the start of its own name — the /projects#${area.anchor} deep link would silently fail to filter.`,
    )
  }
  if (!usedCategoryNames.includes(area.name)) {
    throw new Error(
      `category "${area.name}" is marked featured but no project references it.`,
    )
  }
  getIcon(area.icon!) // throws on an unregistered icon name
}
---

<section class="bg-bg-base py-24">
  <div class="max-w-7xl mx-auto px-6">

    <SectionHeading
      label="What We Do"
      title="Our Focus Areas"
      subtitle="Five pillars of impact that guide every programme we run."
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6 mt-16">
      {areas.map(area => (
        <Card
          title={area.title}
          description={area.description}
          href={`/projects#${area.anchor}`}
          layout="vertical"
        >
          <!-- Icon injected via slot -->
          <Fragment set:html={getIcon(area.icon)} slot="icon" />
        </Card>
      ))}
    </div>

  </div>
</section>
