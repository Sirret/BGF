---
/**
 * FeaturedProjects.astro
 * Displays the 3 featured projects as horizontal cards.
 * Reads from Sanity `project` documents — featured === true, limit 3.
 * Background: bg-white.
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Card from '@components/ui/Card.astro';
import Button from '@components/ui/Button.astro';
import { getFeaturedProjects } from '@lib/sanity/queries';

const projects = await getFeaturedProjects(3);
---

<section class='bg-white py-24'>
	<div class='max-w-7xl mx-auto px-6'>
		<SectionHeading
			label='Our Work'
			title='Featured Projects'
			subtitle='A snapshot of the programmes making a real difference on the ground.'
		/>

		<div class='flex flex-col gap-6 mt-16 max-w-4xl mx-auto'>
			{
				projects.map((project) => (
					<Card
						layout='horizontal'
						image={project.image}
						imageAlt={project.title}
						title={project.title}
						category={project.category.name}
						status={project.status}
						description={project.description}
						impact={project.impact}
						href={`/projects/${project.slug}`}
					/>
				))
			}
		</div>

		<div class='flex justify-center mt-12'>
			<Button
				variant='outline'
				href='/projects'
				>View All Projects</Button
			>
		</div>
	</div>
</section>
