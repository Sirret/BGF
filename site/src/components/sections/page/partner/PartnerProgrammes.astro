---
/**
 * PartnerProgrammes.astro
 * Partner page — our flagship programmes (title + description cards, no
 * images). All content pulled from Sanity partnerPage — edit there, not here.
 * Background: bg-bg-base
 *
 * Props:
 *   heading    — programmesSection object from partnerPage {label,title,subtitle}
 *   programmes — array of {title, description} from partnerPage
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Card from '@components/ui/Card.astro';

interface Programme {
	title: string;
	description?: string;
}

const { heading, programmes } = Astro.props as {
	heading: { label?: string; title: string; subtitle?: string };
	programmes: Programme[];
};
---

<section class='bg-bg-base py-24'>
	<div class='max-w-7xl mx-auto px-6 flex flex-col gap-14'>
		<SectionHeading
			label={heading.label}
			title={heading.title}
			subtitle={heading.subtitle}
		/>

		<div class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6'>
			{
				programmes.map((programme) => (
					<Card title={programme.title} description={programme.description} />
				))
			}
		</div>
	</div>
</section>
