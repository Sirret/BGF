---
/**
 * PartnerServices.astro
 * Partner page — consultancy & capacity-building services checklist, plus
 * the closing "who we partner with" blurb. Content from Sanity partnerPage.
 * Background: bg-white
 *
 * Props:
 *   heading — servicesSection object from partnerPage {label,title,subtitle}
 *   services — array of strings from partnerPage
 *   blurb    — partnersBlurb string from partnerPage
 */

import SectionHeading from '@components/ui/SectionHeading.astro';

const { heading, services, blurb } = Astro.props as {
	heading: { label?: string; title: string; subtitle?: string };
	services: string[];
	blurb?: string;
};
---

<section class='bg-white py-24'>
	<div class='max-w-5xl mx-auto px-6 flex flex-col gap-14'>
		<SectionHeading
			label={heading.label}
			title={heading.title}
			subtitle={heading.subtitle}
		/>

		<div class='grid grid-cols-1 sm:grid-cols-2 gap-4'>
			{
				services.map((service) => (
					<div class='flex items-start gap-3 bg-bg-base border border-border rounded-xl px-5 py-4'>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							class='w-5 h-5 text-accent flex-shrink-0 mt-0.5'
							fill='none'
							viewBox='0 0 24 24'
							stroke='currentColor'
							stroke-width='2'
						>
							<path stroke-linecap='round' stroke-linejoin='round' d='M5 13l4 4L19 7' />
						</svg>
						<span class='font-body text-sm text-text-dark leading-relaxed'>{service}</span>
					</div>
				))
			}
		</div>

		{
			blurb && (
				<p class='font-body text-text-muted text-center leading-relaxed max-w-3xl mx-auto'>
					{blurb}
				</p>
			)
		}
	</div>
</section>
