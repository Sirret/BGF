---
/**
 * NewsGrid.astro
 * News page — full grid of all articles with a client-side category filter.
 * Reads from Sanity `newsArticle` documents.
 * Background: bg-white
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Card from '@components/ui/Card.astro';
import { getAllNews } from '@lib/sanity/queries';
import { withBase } from '@components/utils/paths';
import { formatDate } from '@components/utils/dates';

const news = await getAllNews();

// Unique types, in first-seen order, for the filter bar
const types = [...new Set(news.map((n) => n.type))];
---

<section class='bg-white py-24'>
	<div class='max-w-7xl mx-auto px-6'>
		<SectionHeading
			label='Latest Updates'
			title='News & Announcements'
			subtitle='Programme launches, partnerships, and stories from the communities we work alongside.'
		/>

		<!-- Filter bar -->
		<div
			class='flex flex-wrap justify-center gap-3 mt-12'
			role='group'
			aria-label='Filter news by type'
		>
			<button
				type='button'
				class='project-filter-btn px-5 py-2 rounded-full text-sm font-heading font-semibold border-2 border-primary bg-primary text-white transition-colors duration-200'
				data-filter='all'
				aria-pressed='true'
			>
				All
			</button>
			{
				types.map((type) => (
					<button
						type='button'
						class='project-filter-btn px-5 py-2 rounded-full text-sm font-heading font-semibold border-2 border-primary text-primary hover:bg-primary hover:text-white transition-colors duration-200'
						data-filter={type}
						aria-pressed='false'
					>
						{type}
					</button>
				))
			}
		</div>

		<!-- Grid -->
		<div
			class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mt-16'
			id='project-grid'
		>
			{
				news.map((article) => (
					<div
						class='project-card'
						data-category={article.type}
					>
						<Card
							layout='vertical'
							image={article.image}
							imageAlt={article.title}
							title={article.title}
							category={article.type}
							description={article.excerpt}
							impact={formatDate(article.date) ? `Published ${formatDate(article.date)}` : undefined}
							href={`/news/${article.slug}`}
						/>
					</div>
				))
			}
		</div>

		<!-- Empty state — shown when a filter matches nothing -->
		<p
			id='project-empty-state'
			class='hidden text-center text-text-muted font-body mt-16'
		>
			No news found in this category yet.
		</p>
	</div>
</section>

<!-- External, non-processed script — CSP: script-src 'self' works with zero exceptions -->
<script
	src={withBase('/scripts/project-filter.js')}
	is:inline
></script>
