---
/**
 * DonateInfo.astro
 * Get Involved page — compact donate teaser linking out to the full /donate
 * page. Bank transfer and mobile money details live there, not duplicated
 * here — see donate.json / pages/donate.astro.
 * Background: bg-bg-base
 *
 * Props: data — donateSection object from get-involved.json
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import Button from '@components/ui/Button.astro';

const { data } = Astro.props;
---

<section class='bg-bg-base py-24'>
	<div
		class='max-w-3xl mx-auto px-6 flex flex-col items-center text-center gap-8'
	>
		<SectionHeading
			label={data.label}
			title={data.title}
			subtitle={data.subtitle}
		/>
		<Button
			variant='accent'
			href={data.ctaHref}
		>
			{data.ctaLabel}
		</Button>
	</div>
</section>
