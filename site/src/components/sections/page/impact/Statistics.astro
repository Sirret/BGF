---
/**
 * Statistics.astro
 * Impact page — bold impact numbers on solid deep-blue background.
 * Reads shared `stat` documents (same source as homepage ImpactStats.astro)
 * and this page's own section heading copy from Sanity impactPage.
 * Background: bg-primary — this page's one reserved statistical section.
 */

import SectionHeading from '@components/ui/SectionHeading.astro';
import StatBlock from '@components/ui/StatBlock.astro';
import { getAllStats, getImpactPage } from '@lib/sanity/queries';

const [stats, impact] = await Promise.all([getAllStats(), getImpactPage()]);
const { statsSection } = impact;
---

<section class='bg-primary py-24'>
	<div class='max-w-7xl mx-auto px-6'>
		<SectionHeading
			light={true}
			label={statsSection.label}
			title={statsSection.title}
			subtitle={statsSection.subtitle}
		/>

		<div
			class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 mt-16'
		>
			{
				stats.map((stat: any) => (
					<StatBlock
						label={stat.label}
						value={stat.value}
						chartData={stat.chartData}
					/>
				))
			}
		</div>
	</div>
</section>
