---
/**
 * ImpactHero.astro
 * Thin shell — reads hero config from Sanity impactPage and passes it to the shared PageHero component.
 */

import PageHero from '@components/ui/PageHero.astro';
import { getImpactPage } from '@lib/sanity/queries';

const impact = await getImpactPage();
---

<PageHero
  title={impact.hero.title}
  subtitle={impact.hero.subtitle}
  breadcrumb={impact.hero.breadcrumb}
  backgroundImage={impact.hero.backgroundImage}
/>
