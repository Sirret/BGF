---
/**
 * pages/news/[slug].astro
 * Individual news article page — statically generated for every valid
 * entry in news.json.
 *
 * Section order:
 *   1. NewsDetailHero    — breadcrumb, category badge, title, meta
 *   2. NewsDetailContent — cover image, body, optional gallery, facts sidebar
 *   3. RelatedNews       — up to 3 other articles, same category first
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import NewsDetailHero from '@components/sections/page/news-detail/NewsDetailHero.astro';
import NewsDetailContent from '@components/sections/page/news-detail/NewsDetailContent.astro';
import RelatedNews from '@components/sections/page/news-detail/RelatedNews.astro';
import allNews from '@data/news.json';
import { hasStringFields, findDuplicates } from '@components/utils/validate';

export function getStaticPaths() {
	// Same guard as NewsGrid.astro — drop any stray entry missing a slug/title
	// rather than let it generate a broken route.
	const valid = (allNews as unknown[]).filter((n) =>
		hasStringFields(n as Record<string, unknown>, ['slug', 'title']),
	) as { slug: string; title: string }[];

	// A duplicate slug makes Astro silently render only the first match and
	// drop the second entry's content with no build failure — fail loudly
	// instead so a bad news.json edit can't ship unnoticed.
	const duplicateSlugs = findDuplicates(valid.map((n) => n.slug));
	if (duplicateSlugs.length > 0) {
		throw new Error(
			`news.json has duplicate slug(s): ${duplicateSlugs.join(', ')}. Slugs must be unique — fix news.json before building.`,
		);
	}

	return valid.map((article: any) => ({
		params: { slug: article.slug },
		props: { article },
	}));
}

const { article } = Astro.props;
---

<BaseLayout
	title={article.title}
	description={article.excerpt}
>
	<NewsDetailHero article={article} />
	<NewsDetailContent article={article} />
	<RelatedNews
		currentSlug={article.slug}
		type={article.type}
	/>
</BaseLayout>
