---
/**
 * pages/news/[slug].astro
 * Individual news article page — statically generated for every `newsArticle`
 * document in Sanity.
 *
 * Section order:
 *   1. NewsDetailHero    — breadcrumb, category badge, title, meta
 *   2. NewsDetailContent — cover image, body, optional gallery, facts sidebar
 *   3. RelatedNews       — up to 3 other articles, same category first
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import NewsDetailHero from '@components/sections/page/news-detail/NewsDetailHero.astro';
import NewsDetailContent from '@components/sections/page/news-detail/NewsDetailContent.astro';
import RelatedNews from '@components/sections/page/news-detail/RelatedNews.astro';
import { getAllNews } from '@lib/sanity/queries';
import { findDuplicates } from '@components/utils/validate';

export async function getStaticPaths() {
	// The full document shape is needed here, not a slug-only list — Astro.props
	// receives the whole object at build time, no separate per-page fetch.
	const news = await getAllNews();

	// A duplicate slug makes Astro silently render only the first match and
	// drop the second entry's content with no build failure — fail loudly
	// instead so a bad Sanity edit can't ship unnoticed. Sanity does not
	// enforce cross-document slug uniqueness on its own.
	const duplicateSlugs = findDuplicates(news.map((n) => n.slug));
	if (duplicateSlugs.length > 0) {
		throw new Error(
			`Sanity has newsArticle documents with duplicate slug(s): ${duplicateSlugs.join(', ')}. Slugs must be unique — fix in Studio before building.`,
		);
	}

	return news.map((article) => ({
		params: { slug: article.slug },
		props: { article },
	}));
}

const { article } = Astro.props;
---

<BaseLayout
	title={article.title}
	description={article.excerpt}
>
	<NewsDetailHero article={article} />
	<NewsDetailContent article={article} />
	<RelatedNews
		currentSlug={article.slug}
		type={article.type}
	/>
</BaseLayout>
