---
/**
 * pages/projects/[slug].astro
 * Individual project detail page — statically generated for every `project`
 * document in Sanity. Fixes the previously-dead /projects/{slug} links used
 * by every project Card across the site (homepage Featured Projects and the
 * Projects page grid both link here).
 *
 * Section order:
 *   1. ProjectDetailHero    — breadcrumb, category/status badges, title, meta
 *   2. ProjectDetailContent — cover image, description, impact, gallery, facts sidebar, downloads
 *   3. RelatedProjects      — up to 3 other projects, same category first
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectDetailHero from '@components/sections/page/project-detail/ProjectDetailHero.astro';
import ProjectDetailContent from '@components/sections/page/project-detail/ProjectDetailContent.astro';
import RelatedProjects from '@components/sections/page/project-detail/RelatedProjects.astro';
import { getAllProjects } from '@lib/sanity/queries';
import { findDuplicates } from '@components/utils/validate';

export async function getStaticPaths() {
	// The full document shape is needed here, not a slug-only list — Astro.props
	// receives the whole object at build time, no separate per-page fetch.
	const projects = await getAllProjects();

	// A duplicate slug makes Astro silently render only the first match and
	// drop the second entry's content with no build failure — fail loudly
	// instead so a bad Sanity edit can't ship unnoticed. Sanity does not
	// enforce cross-document slug uniqueness on its own.
	const duplicateSlugs = findDuplicates(projects.map((p) => p.slug));
	if (duplicateSlugs.length > 0) {
		throw new Error(
			`Sanity has project documents with duplicate slug(s): ${duplicateSlugs.join(', ')}. Slugs must be unique — fix in Studio before building.`,
		);
	}

	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
---

<BaseLayout
	title={project.title}
	description={project.description}
>
	<ProjectDetailHero project={project} />
	<ProjectDetailContent project={project} />
	<RelatedProjects
		currentSlug={project.slug}
		category={project.category.name}
	/>
</BaseLayout>
