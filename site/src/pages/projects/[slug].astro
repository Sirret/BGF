---
/**
 * pages/projects/[slug].astro
 * Individual project detail page — statically generated for every valid
 * entry in projects.json. Fixes the previously-dead /projects/{slug} links
 * used by every project Card across the site (homepage Featured Projects
 * and the Projects page grid both link here).
 *
 * Section order:
 *   1. ProjectDetailHero    — breadcrumb, category/status badges, title, meta
 *   2. ProjectDetailContent — cover image, description, impact, gallery, facts sidebar, downloads
 *   3. RelatedProjects      — up to 3 other projects, same category first
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectDetailHero from '@components/sections/page/project-detail/ProjectDetailHero.astro';
import ProjectDetailContent from '@components/sections/page/project-detail/ProjectDetailContent.astro';
import RelatedProjects from '@components/sections/page/project-detail/RelatedProjects.astro';
import allProjects from '@data/projects.json';
import { hasStringFields, findDuplicates } from '@components/utils/validate';

export function getStaticPaths() {
	// Same guard as ProjectGrid.astro — drop any stray entry missing a slug/title
	// rather than let it generate a broken route.
	const valid = (allProjects as unknown[]).filter((p) =>
		hasStringFields(p as Record<string, unknown>, ['slug', 'title']),
	) as { slug: string; title: string }[];

	// A duplicate slug makes Astro silently render only the first match and
	// drop the second entry's content with no build failure — fail loudly
	// instead so a bad projects.json edit can't ship unnoticed.
	const duplicateSlugs = findDuplicates(valid.map((p) => p.slug));
	if (duplicateSlugs.length > 0) {
		throw new Error(
			`projects.json has duplicate slug(s): ${duplicateSlugs.join(', ')}. Slugs must be unique — fix projects.json before building.`,
		);
	}

	return valid.map((project: any) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
---

<BaseLayout
	title={project.title}
	description={project.description}
>
	<ProjectDetailHero project={project} />
	<ProjectDetailContent project={project} />
	<RelatedProjects
		currentSlug={project.slug}
		category={project.category}
	/>
</BaseLayout>
